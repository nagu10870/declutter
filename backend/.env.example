# App
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ENCRYPTION_KEY=your-fernet-key-run-python-cryptography-fernet-generate-key

# Database
DATABASE_URL=postgresql+asyncpg://declutter:declutter@localhost:5432/declutter_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Email
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Storage (for thumbnails)
R2_ENDPOINT=https://...r2.cloudflarestorage.com
R2_ACCESS_KEY=...
R2_SECRET_KEY=...
R2_BUCKET=declutter-thumbnails

# Frontend
FRONTEND_URL=http://localhost:3000

# ── Month 2: Thumbnail Storage (Cloudflare R2) ────────────────────────────
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=declutter-thumbnails
THUMBNAIL_BASE_URL=https://cdn.yourdomain.com

# Month 2: pHash sensitivity (Hamming distance, 1-30, default 10)
PHASH_SIMILARITY_THRESHOLD=10

# Month 2: OneDrive (stub, enabled Month 3)
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=

# ── Month 3: AI Classification ────────────────────────────────────────────
OPENAI_API_KEY=sk-...                # Optional: GPT-4o Mini for receipt/doc classification (Pro)
BLUR_THRESHOLD=100.0                 # Laplacian variance threshold (lower = more blurry)
AI_MAX_FILE_BYTES=5000000            # Max thumbnail size to send to OpenAI (5MB)

# Month 3: OneDrive OAuth
ONEDRIVE_CLIENT_ID=your-azure-app-client-id
ONEDRIVE_CLIENT_SECRET=your-azure-app-secret
ONEDRIVE_TENANT_ID=common            # Use 'common' for multi-tenant apps

# Month 3: Stripe Billing (already partially present, added yearly price)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_yyy
